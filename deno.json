{
  "name": "@tangerie/power-automate-connector",
  "version": "1.0.1",
  "license": "MIT",
  "publish": {
    "include": [
      "README.md",
      "src/**/*.ts",
      "tool/**/*.ts"
    ],
    "exclude": [
      "examples",
      ".env",
      "connector"
    ]
  },
  "exports": {
    ".": "./src/mod.ts",
    "./swagger": "./tool/swagger.ts"
  },
  "tasks": {
    "dry": "deno publish --dry-run --allow-dirty"
  },
  "imports": {
    "@oak/oak": "jsr:@oak/oak@^17.2.0",
    "@std/assert": "jsr:@std/assert@1",
    "@std/cli": "jsr:@std/cli@^1.0.32",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.7",
    "@std/path": "jsr:@std/path@^1.1.6",
    "@zod/zod": "jsr:@zod/zod@^4.4.3"
  }
}
